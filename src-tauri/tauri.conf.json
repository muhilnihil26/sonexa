{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sonexa",
  "version": "1.0.3",
  "identifier": "com.wardev.sonexa",
  "build": {
    "frontendDist": "https://sonexa-listen-beyond-main.vercel.app",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sonexa — Listen Beyond Limits",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "copyright": "Copyright © 2025 War.Dev",
    "category": "Music",
    "publisher": "War.Dev",
    "longDescription": "Sonexa — Premium AI-powered Tamil music streaming. Listen Beyond Limits."
  }
}
